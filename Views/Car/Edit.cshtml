@model ExpressVoitures.Domain.Car

@{
    ViewData["Title"] = "Modifier la voiture";
    ViewData["Page"] = "Accueil";
}

<div style="padding: 48px 64px; max-width: 600px; margin: 0 auto;">

    <!-- Titre -->
    <div class="text-center" style="margin-bottom: 32px;">
        <h1 class="titre-principal">Modifier la voiture</h1>
    </div>

    <!-- Formulaire -->
    <form asp-controller="Car"
          asp-action="Edit"
          method="post"
          enctype="multipart/form-data">

        @Html.AntiForgeryToken()

        <!-- Champ caché pour l'Id — indispensable pour que EF Core
             sache quelle voiture modifier -->
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="PhotoUrl" />

        <!-- Messages d'erreur globaux -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert" role="alert"
                 style="background: #fdf0f0; border: 1px solid var(--ev-rouge);
                            border-radius: 6px; padding: 12px 16px; margin-bottom: 24px;
                            color: var(--ev-rouge); font-size: 14px;">
                Veuillez corriger les erreurs ci-dessous.
            </div>
        }

        <!-- Prix d'achat -->
        <div style="margin-bottom: 20px;">
            <label asp-for="PurchasePrice"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Prix d'achat (€)
            </label>
            <input asp-for="PurchasePrice"
                   type="number"
                   step="0.01"
                   min="0"
                   style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                          border-radius: 6px; font-size: 15px; color: var(--ev-marron);"
                   aria-required="true" />
            <span asp-validation-for="PurchasePrice"
                  style="color: var(--ev-rouge); font-size: 13px;"></span>
        </div>

        <!-- Année -->
        <div style="margin-bottom: 20px;">
            <label asp-for="Year"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Année
            </label>
            <input asp-for="Year"
                   type="number"
                   min="1990"
                   max="@DateTime.Now.Year"
                   style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                          border-radius: 6px; font-size: 15px; color: var(--ev-marron);"
                   aria-required="true" />
            <span asp-validation-for="Year"
                  style="color: var(--ev-rouge); font-size: 13px;"></span>
        </div>

        <!-- Marque -->
        <div style="margin-bottom: 20px;">
            <label for="BrandId"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Marque
            </label>
            <select id="BrandId"
                    name="BrandId"
                    style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                           border-radius: 6px; font-size: 15px; color: var(--ev-marron);
                           background: white;"
                    aria-required="true">
                <option value="">-- Sélectionnez une marque --</option>
                @foreach (var brand in ViewBag.Brands as
                                IEnumerable<ExpressVoitures.Domain.Brand>)
                {
                    <option value="@brand.Id"
                            selected="@(brand.Id == Model.CarModel?.BrandId)">
                        @brand.Name
                    </option>
                }
            </select>
        </div>

        <!-- Modèle -->
        <div style="margin-bottom: 20px;">
            <label for="CarModelId"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Modèle
            </label>
            <select id="CarModelId"
                    name="CarModelId"
                    asp-for="CarModelId"
                    style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                           border-radius: 6px; font-size: 15px; color: var(--ev-marron);
                           background: white;"
                    aria-required="true">
                <option value="@Model.CarModelId">
                    @Model.CarModel?.Name
                </option>
            </select>
            <span asp-validation-for="CarModelId"
                  style="color: var(--ev-rouge); font-size: 13px;"></span>
        </div>

        <!-- Finition -->
        <div style="margin-bottom: 20px;">
            <label for="TrimId"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Finition
            </label>
            <select id="TrimId"
                    name="TrimId"
                    asp-for="TrimId"
                    style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                           border-radius: 6px; font-size: 15px; color: var(--ev-marron);
                           background: white;"
                    aria-required="true">
                <option value="@Model.TrimId">
                    @Model.Trim?.Name
                </option>
            </select>
            <span asp-validation-for="TrimId"
                  style="color: var(--ev-rouge); font-size: 13px;"></span>
        </div>

       @*  <!-- Date d'achat -->
        <div style="margin-bottom: 20px;">
            <label asp-for="PurchaseDate"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Date d'achat
            </label>
            <input asp-for="PurchaseDate"
                   type="date"
                   style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                          border-radius: 6px; font-size: 15px; color: var(--ev-marron);"
                   aria-required="true" />
            <span asp-validation-for="PurchaseDate"
                  style="color: var(--ev-rouge); font-size: 13px;"></span>
        </div> *@

        <!-- Description -->
        <div style="margin-bottom: 20px;">
            <label asp-for="Description"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Description
                <span style="color: var(--ev-gris-texte); font-size: 12px;">
                    (optionnel)
                </span>
            </label>
            <textarea asp-for="Description"
                      rows="4"
                      style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                             border-radius: 6px; font-size: 15px; color: var(--ev-marron);
                             resize: vertical;"></textarea>
        </div>

        <!-- Photo actuelle + remplacement -->
        <div style="margin-bottom: 32px;">
            <label for="PhotoFile"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Visuel
                <span style="color: var(--ev-gris-texte); font-size: 12px;">
                    (laisser vide pour garder la photo actuelle)
                </span>
            </label>

            @if (!string.IsNullOrEmpty(Model.PhotoUrl))
            {
                <img src="@Model.PhotoUrl"
                     alt="Photo actuelle"
                     style="width: 100%; max-height: 200px; object-fit: cover;
                                border-radius: 6px; margin-bottom: 12px;" />
            }

            <div style="border: 1px solid #d0c8be; border-radius: 6px;
                        padding: 24px; text-align: center; background: #faf8f5;">
                <input type="file"
                       id="PhotoFile"
                       name="PhotoFile"
                       accept="image/*"
                       style="font-size: 14px; color: var(--ev-gris-texte);"
                       aria-label="Remplacer la photo de la voiture" />
            </div>
        </div>

        <!-- Boutons -->
        <div class="d-flex justify-content-between align-items-center">
            <a asp-controller="Car"
               asp-action="Details"
               asp-route-id="@Model.Id"
               class="lien-retour">
                ← Annuler
            </a>
            <button type="submit" class="btn-express">
                Enregistrer
            </button>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        // Pré-charge les modèles de la marque actuelle au chargement de la page
        window.addEventListener('load', function () {
            var brandId = document.getElementById('BrandId').value;
            var currentModelId = @Model.CarModelId;
            var currentTrimId = @Model.TrimId;

            if (brandId) {
                fetch('/Car/GetModelsByBrand?brandId=' + brandId)
                    .then(r => r.json())
                    .then(models => {
                        var modelSelect = document.getElementById('CarModelId');
                        modelSelect.innerHTML = '';
                        models.forEach(function (m) {
                            var opt = document.createElement('option');
                            opt.value = m.id;
                            opt.textContent = m.name;
                            if (m.id === currentModelId) opt.selected = true;
                            modelSelect.appendChild(opt);
                        });

                        // Ensuite charge les finitions du modèle actuel
                        return fetch('/Car/GetTrimsByModel?carModelId=' + currentModelId);
                    })
                    .then(r => r.json())
                    .then(trims => {
                        var trimSelect = document.getElementById('TrimId');
                        trimSelect.innerHTML = '';
                        trims.forEach(function (t) {
                            var opt = document.createElement('option');
                            opt.value = t.id;
                            opt.textContent = t.name;
                            if (t.id === currentTrimId) opt.selected = true;
                            trimSelect.appendChild(opt);
                        });
                    });
            }
        });

        // Changement de marque → recharge les modèles
        document.getElementById('BrandId').addEventListener('change', function () {
            var brandId = this.value;
            var modelSelect = document.getElementById('CarModelId');
            var trimSelect = document.getElementById('TrimId');

            modelSelect.innerHTML = '<option value="">-- Choisissez un modèle --</option>';
            trimSelect.innerHTML = '<option value="">-- Choisissez une finition --</option>';

            if (brandId) {
                fetch('/Car/GetModelsByBrand?brandId=' + brandId)
                    .then(r => r.json())
                    .then(models => {
                        models.forEach(function (m) {
                            var opt = document.createElement('option');
                            opt.value = m.id;
                            opt.textContent = m.name;
                            modelSelect.appendChild(opt);
                        });
                    });
            }
        });

        // Changement de modèle → recharge les finitions
        document.getElementById('CarModelId').addEventListener('change', function () {
            var carModelId = this.value;
            var trimSelect = document.getElementById('TrimId');

            trimSelect.innerHTML = '<option value="">-- Choisissez une finition --</option>';

            if (carModelId) {
                fetch('/Car/GetTrimsByModel?carModelId=' + carModelId)
                    .then(r => r.json())
                    .then(trims => {
                        trims.forEach(function (t) {
                            var opt = document.createElement('option');
                            opt.value = t.id;
                            opt.textContent = t.name;
                            trimSelect.appendChild(opt);
                        });
                    });
            }
        });
    </script>
}