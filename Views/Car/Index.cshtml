@model ExpressVoitures.Models.CarIndexViewModel

@{
    ViewData["Title"] = "Nos voitures";
    ViewData["Page"] = "Accueil";
}

<div style="padding: 48px 64px;">

    <!-- Titre + bouton ajout (visible uniquement si connecté) -->
    <div class="text-center" style="margin-bottom: 48px;">
        <h1 class="titre-principal">Nos voitures</h1>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <a class="btn-express" style="margin-top: 16px;"
               asp-controller="Car"
               asp-action="Create">
                + Ajouter une voiture
            </a>
        }
    </div>

    <!-- Grille de voitures -->
    @if (!Model.Cars.Any())
    {
        <p style="text-align:center; color: var(--ev-gris-texte);">
            Aucune voiture disponible pour le moment.
        </p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var car in Model.Cars.Where(c => c.IsAvailable))
            {
                <div class="col">
                    <a asp-controller="Car"
                       asp-action="Details"
                       asp-route-id="@car.Id"
                       style="text-decoration: none; color: inherit;">

                        <div class="d-flex align-items-stretch"
                             style="border: 1px solid #f0ebe4; border-radius: 8px; overflow: hidden; min-height: 220px;">

                            <!-- Photo -->
                            <div style="width: 55%; flex-shrink: 0;">
                                @if (!string.IsNullOrEmpty(car.PhotoUrl))
                                {
                                    <img src="@car.PhotoUrl"
                                         alt="Photo de la @car.CarModel?.Brand?.Name @car.CarModel?.Name"
                                         style="width: 100%; height: 100%; object-fit: cover;" />
                                }
                                else
                                {
                                    <div style="width:100%; height:100%; background:#f5f0eb;
                                                            display:flex; align-items:center; justify-content:center;
                                                            color: var(--ev-gris-texte); font-size: 14px;">
                                        Aucune photo
                                    </div>
                                }
                            </div>

                            <!-- Infos -->
                            <div style="padding: 24px; flex-grow: 1;">
                                <p style="font-weight: 700; font-size: 18px; margin-bottom: 12px;">
                                    @Model.GetSellingPrice(car.Id).ToString("C", new System.Globalization.CultureInfo("fr-FR"))
                                </p>
                                <p style="color: var(--ev-gris-texte); font-size: 14px; margin-bottom: 6px;">
                                    @car.Year
                                </p>
                                <p style="color: var(--ev-gris-texte); font-size: 14px; margin-bottom: 6px;">
                                    @car.CarModel?.Brand?.Name
                                </p>
                                <p style="color: var(--ev-gris-texte); font-size: 14px; margin-bottom: 6px;">
                                    @car.CarModel?.Name
                                </p>
                                <p style="color: var(--ev-gris-texte); font-size: 14px; margin-bottom: 0;">
                                    @car.Trim?.Name
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>