@model ExpressVoitures.Domain.Car

@{
    ViewData["Title"] = "Ajouter une voiture";
    ViewData["Page"] = "Ajouter";
}

<div style="padding: 48px 64px; max-width: 600px; margin: 0 auto;">

    <!-- Titre -->
    <div class="text-center" style="margin-bottom: 32px;">
        <h1 class="titre-principal">Ajouter une voiture</h1>
        <p style="color: var(--ev-gris-texte); font-size: 14px;">
            tous les champs sont obligatoires
        </p>
    </div>

    <!-- Formulaire -->
    <form asp-controller="Car"
          asp-action="Create"
          method="post"
          enctype="multipart/form-data">

        @Html.AntiForgeryToken()

        <!-- Messages d'erreur globaux -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert" role="alert"
                 style="background: #fdf0f0; border: 1px solid var(--ev-rouge);
                            border-radius: 6px; padding: 12px 16px; margin-bottom: 24px;
                            color: var(--ev-rouge); font-size: 14px;">
                Veuillez corriger les erreurs ci-dessous.
            </div>
        }

        <!-- Prix d'achat -->
        <div style="margin-bottom: 20px;">
            <label asp-for="PurchasePrice"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Prix d'achat (€)
            </label>
            <input asp-for="PurchasePrice"
                   type="number"
                   step="0.01"
                   min="0"
                   style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                          border-radius: 6px; font-size: 15px; color: var(--ev-marron);"
                   aria-required="true" />
            <span asp-validation-for="PurchasePrice"
                  style="color: var(--ev-rouge); font-size: 13px;"></span>
        </div>

        <!-- Année -->
        <div style="margin-bottom: 20px;">
            <label asp-for="Year"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Année
            </label>
            <input asp-for="Year"
                   type="number"
                   min="1990"
                   max="@DateTime.Now.Year"
                   style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                          border-radius: 6px; font-size: 15px; color: var(--ev-marron);"
                   aria-required="true" />
            <span asp-validation-for="Year"
                  style="color: var(--ev-rouge); font-size: 13px;"></span>
        </div>

        <!-- Marque -->
        <div style="margin-bottom: 20px;">
            <label for="BrandId"
                   style="display: block; font-size: 14px;
                  margin-bottom: 6px; color: var(--ev-marron);">
                Marque
            </label>
            <select id="BrandId"
                    name="BrandId"
                    style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                   border-radius: 6px; font-size: 15px; color: var(--ev-marron);
                   background: white;"
                    aria-required="true"
                    aria-label="Sélectionnez une marque">
                <option value="">-- Sélectionnez une marque --</option>
                @foreach (var brand in ViewBag.Brands as IEnumerable<ExpressVoitures.Domain.Brand>)
                {
                    <option value="@brand.Id">@brand.Name</option>
                }
                <option value="new">+ Nouvelle marque</option>
            </select>

            <!-- Champ texte caché pour nouvelle marque -->
            <input type="text"
                   id="NewBrand"
                   name="NewBrand"
                   placeholder="Nom de la nouvelle marque"
                   style="display: none; width: 100%; padding: 10px 14px;
                  border: 1px solid var(--ev-dore); border-radius: 6px;
                  font-size: 15px; color: var(--ev-marron); margin-top: 8px;
                  box-sizing: border-box;"
                   aria-label="Nom de la nouvelle marque" />

            <span style="color: var(--ev-rouge); font-size: 13px;"
                  id="BrandError">
                @Html.ValidationMessage("BrandId")
            </span>
            <span style="color: var(--ev-rouge); font-size: 13px;">
                @Html.ValidationMessage("NewBrand")
            </span>
        </div>

        <!-- Modèle -->
        <div style="margin-bottom: 20px;">
            <label for="CarModelId"
                   style="display: block; font-size: 14px;
                  margin-bottom: 6px; color: var(--ev-marron);">
                Modèle
            </label>
            <select id="CarModelId"
                    name="CarModelId"
                    asp-for="CarModelId"
                    style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                   border-radius: 6px; font-size: 15px; color: var(--ev-marron);
                   background: white;"
                    aria-required="true"
                    aria-label="Sélectionnez un modèle"
                    disabled>
                <option value="">-- Choisissez d'abord une marque --</option>
            </select>
            <span asp-validation-for="CarModelId"
                  style="color: var(--ev-rouge); font-size: 13px;"></span>

            <!-- Champ texte caché pour nouveau modèle -->
            <input type="text"
                   id="NewCarModel"
                   name="NewCarModel"
                   placeholder="Nom du nouveau modèle"
                   style="display: none; width: 100%; padding: 10px 14px;
                  border: 1px solid var(--ev-dore); border-radius: 6px;
                  font-size: 15px; color: var(--ev-marron); margin-top: 8px;
                  box-sizing: border-box;"
                   aria-label="Nom du nouveau modèle" />
        </div>

        <!-- Finition -->
        <div style="margin-bottom: 20px;">
            <label for="TrimId"
                   style="display: block; font-size: 14px;
                  margin-bottom: 6px; color: var(--ev-marron);">
                Finition
            </label>
            <select id="TrimId"
                    name="TrimId"
                    asp-for="TrimId"
                    style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                   border-radius: 6px; font-size: 15px; color: var(--ev-marron);
                   background: white;"
                    aria-required="true"
                    aria-label="Sélectionnez une finition"
                    disabled>
                <option value="">-- Choisissez d'abord un modèle --</option>
            </select>
            <span asp-validation-for="TrimId"
                  style="color: var(--ev-rouge); font-size: 13px;"></span>

            <!-- Champ texte caché pour nouvelle finition -->
            <input type="text"
                   id="NewTrim"
                   name="NewTrim"
                   placeholder="Nom de la nouvelle finition"
                   style="display: none; width: 100%; padding: 10px 14px;
                  border: 1px solid var(--ev-dore); border-radius: 6px;
                  font-size: 15px; color: var(--ev-marron); margin-top: 8px;
                  box-sizing: border-box;"
                   aria-label="Nom de la nouvelle finition" />
        </div>

        @* <!-- Date d'achat -->
        <div style="margin-bottom: 20px;">
            <label asp-for="PurchaseDate"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Date d'achat
            </label>
            <input asp-for="PurchaseDate"
                   type="date"
                   style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                          border-radius: 6px; font-size: 15px; color: var(--ev-marron);"
                   aria-required="true" />
            <span asp-validation-for="PurchaseDate"
                  style="color: var(--ev-rouge); font-size: 13px;"></span>
        </div> *@

        <!-- Description (optionnel) -->
        <div style="margin-bottom: 20px;">
            <label asp-for="Description"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Description
                <span style="color: var(--ev-gris-texte); font-size: 12px;">
                    (optionnel)
                </span>
            </label>
            <textarea asp-for="Description"
                      rows="4"
                      style="width: 100%; padding: 10px 14px; border: 1px solid #d0c8be;
                             border-radius: 6px; font-size: 15px; color: var(--ev-marron);
                             resize: vertical;"></textarea>
        </div>

        <!-- Photo (optionnel) -->
        <div style="margin-bottom: 32px;">
            <label for="PhotoFile"
                   style="display: block; font-size: 14px;
                          margin-bottom: 6px; color: var(--ev-marron);">
                Visuel
                <span style="color: var(--ev-gris-texte); font-size: 12px;">
                    (optionnel)
                </span>
            </label>
            <div style="border: 1px solid #d0c8be; border-radius: 6px;
                        padding: 24px; text-align: center; background: #faf8f5;">
                <input type="file"
                       id="PhotoFile"
                       name="PhotoFile"
                       accept="image/*"
                       style="font-size: 14px; color: var(--ev-gris-texte);"
                       aria-label="Ajouter une image de la voiture" />
            </div>
        </div>

        <!-- Bouton Publier -->
        <div class="text-center">
            <button type="submit" class="btn-express">
                Publier
            </button>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        // ── Marque ──────────────────────────────────────────
        document.getElementById('BrandId').addEventListener('change', function () {
            var brandId = this.value;
            var newBrandInput = document.getElementById('NewBrand');
            var modelSelect = document.getElementById('CarModelId');
            var newModelInput = document.getElementById('NewCarModel');
            var trimSelect = document.getElementById('TrimId');
            var newTrimInput = document.getElementById('NewTrim');

            // Réinitialise modèle et finition
            modelSelect.innerHTML = '<option value="">-- Choisissez un modèle --</option>';
            trimSelect.innerHTML = '<option value="">-- Choisissez d\'abord un modèle --</option>';
            modelSelect.disabled = true;
            trimSelect.disabled = true;
            newModelInput.style.display = 'none';
            newTrimInput.style.display = 'none';

            if (brandId === 'new') {
                // Affiche le champ texte pour nouvelle marque
                newBrandInput.style.display = 'block';
                newBrandInput.required = true;

                // Active directement le champ nouveau modèle
                newModelInput.style.display = 'block';
                newModelInput.required = true;
                modelSelect.disabled = false;

                // Ajoute l'option "nouveau modèle" dans le select
                modelSelect.innerHTML = '<option value="new">+ Nouveau modèle</option>';

                // Active la finition
                newTrimInput.style.display = 'block';
                newTrimInput.required = true;
                trimSelect.disabled = false;
                trimSelect.innerHTML = '<option value="new">+ Nouvelle finition</option>';

            } else if (brandId) {
                // Marque existante → cache le champ texte
                newBrandInput.style.display = 'none';
                newBrandInput.required = false;

                // Charge les modèles via AJAX
                fetch('/Car/GetModelsByBrand?brandId=' + brandId)
                    .then(r => r.json())
                    .then(models => {
                        models.forEach(function (m) {
                            var opt = document.createElement('option');
                            opt.value = m.id;
                            opt.textContent = m.name;
                            modelSelect.appendChild(opt);
                        });
                        // Ajoute l'option nouveau modèle à la fin
                        var newOpt = document.createElement('option');
                        newOpt.value = 'new';
                        newOpt.textContent = '+ Nouveau modèle';
                        modelSelect.appendChild(newOpt);
                        modelSelect.disabled = false;
                    });
            } else {
                newBrandInput.style.display = 'none';
                newBrandInput.required = false;
            }
        });

        // ── Modèle ──────────────────────────────────────────
        document.getElementById('CarModelId').addEventListener('change', function () {
            var carModelId = this.value;
            var newModelInput = document.getElementById('NewCarModel');
            var trimSelect = document.getElementById('TrimId');
            var newTrimInput = document.getElementById('NewTrim');

            trimSelect.innerHTML = '<option value="">-- Choisissez une finition --</option>';
            trimSelect.disabled = true;
            newTrimInput.style.display = 'none';
            newTrimInput.required = false;

            if (carModelId === 'new') {
                // Affiche le champ texte pour nouveau modèle
                newModelInput.style.display = 'block';
                newModelInput.required = true;

                // Active directement la finition
                newTrimInput.style.display = 'block';
                newTrimInput.required = true;
                trimSelect.disabled = false;
                trimSelect.innerHTML = '<option value="new">+ Nouvelle finition</option>';

            } else if (carModelId) {
                newModelInput.style.display = 'none';
                newModelInput.required = false;

                // Charge les finitions via AJAX
                fetch('/Car/GetTrimsByModel?carModelId=' + carModelId)
                    .then(r => r.json())
                    .then(trims => {
                        trims.forEach(function (t) {
                            var opt = document.createElement('option');
                            opt.value = t.id;
                            opt.textContent = t.name;
                            trimSelect.appendChild(opt);
                        });
                        // Ajoute l'option nouvelle finition à la fin
                        var newOpt = document.createElement('option');
                        newOpt.value = 'new';
                        newOpt.textContent = '+ Nouvelle finition';
                        trimSelect.appendChild(newOpt);
                        trimSelect.disabled = false;
                    });
            }
        });

        // ── Finition ─────────────────────────────────────────
        document.getElementById('TrimId').addEventListener('change', function () {
            var trimId = this.value;
            var newTrimInput = document.getElementById('NewTrim');

            if (trimId === 'new') {
                newTrimInput.style.display = 'block';
                newTrimInput.required = true;
            } else {
                newTrimInput.style.display = 'none';
                newTrimInput.required = false;
            }
        });
    </script>
}